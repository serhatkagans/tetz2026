rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // students: herkes okuyabilir; yeni kayıtlar onaylandi:false ile gelmeli;
    // istemciden onaylandi:true yazılamaz (yalnızca admin/console üzerinden).
    match /students/{studentId} {
      allow read: if true;

      allow create: if request.resource.data.onaylandi == false;

      allow update: if
        // mevcut onaylı kayıtlar istemciden değiştirilemez
        resource.data.onaylandi == false
        // güncelleme sonrası onaylandi alanı true'ya yükseltilemez
        && request.resource.data.onaylandi == false;

      allow delete: if false;
    }

    // matches: herkes okuyabilir; istemciden yazılamaz (sunucu/admin tarafından üretilir).
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // meetings: yalnızca ilgili kullanıcılar okuyabilir/yazabilir.
    // participants: meeting dokümanındaki katılımcı uid listesi.
    match /meetings/{meetingId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.participants;
    }
  }
}
